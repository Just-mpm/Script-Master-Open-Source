# Firebase Web SDK (obrigatorio)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# App Check
# Producao: informe uma chave reCAPTCHA v3 autorizada para seu dominio.
# Dev com backend real: registre um debug token no Firebase Console e informe aqui.
# Nunca commite um debug token real.
VITE_RECAPTCHA_SITE_KEY=
VITE_APP_CHECK_DEBUG_TOKEN=

# Analytics
VITE_FIREBASE_ANALYTICS_ENABLED=false

# Emuladores (desenvolvimento local)
VITE_USE_EMULATORS=false
VITE_EMULATOR_AUTH=false
VITE_EMULATOR_FIRESTORE=false
VITE_EMULATOR_STORAGE=false
VITE_EMULATOR_FUNCTIONS=false
VITE_EMULATOR_HOSTING=false
VITE_EMULATOR_UI=false

# Pexels (opcional — sem ele, Stock Media Picker usa placeholder local)
# Plano free: 200 requisições/hora. Gere em https://www.pexels.com/api/
VITE_PEXELS_API_KEY=
