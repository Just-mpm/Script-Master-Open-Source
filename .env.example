# Gemini AI (não consumido pelo frontend — backend usa Genkit via Cloud Functions)
# Mantido para referência de desenvolvimento local legado.
# VITE_GEMINI_API_KEY=""

# reCAPTCHA v3 para App Check
# Em desenvolvimento: opcional (App Check roda em modo debug com token local).
# Em produção: OBRIGATÓRIA — sem ela, App Check não inicializa e todas as
# chamadas httpsCallable do Firebase falham.
VITE_RECAPTCHA_SITE_KEY=""

# Firebase Web SDK (config pública do app)
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="script-master.pro"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_ANALYTICS_ENABLED=""

# Opcional: usado apenas se você quiser apontar para outro banco Firestore.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

# Opcional: Pexels (sem ele, o Stock Media Picker usa placeholder local)
# Plano free: 200 requisições/hora. Gere em https://www.pexels.com/api/
VITE_PEXELS_API_KEY=""

# Opcional: Stripe (sem ele, o app funciona no plano Free)
VITE_STRIPE_PUBLISHABLE_KEY=""

# Modo de operação
VITE_BILLING_ENABLED=false
VITE_OPEN_BETA_ENABLED=true

# Emuladores Firebase (true = conecta frontend aos emuladores locais)
VITE_USE_EMULATORS=false

# Seletor de emuladores individuais (controla CLI e frontend)
# true = emulador ativo, false = emulador desativado
# Se VITE_USE_EMULATORS=true e nenhuma flag abaixo existir, todos conectam (backward compat)
VITE_EMULATOR_AUTH=true
VITE_EMULATOR_FIRESTORE=true
VITE_EMULATOR_STORAGE=true
VITE_EMULATOR_FUNCTIONS=false
VITE_EMULATOR_HOSTING=false
VITE_EMULATOR_UI=false

# App Check Debug Token (desenvolvimento apenas)
# Gere no Console do Firebase > App Check > Gerenciar tokens de depuração.
# Permite rodar local sem reCAPTCHA. NUNCA comite o valor real.
VITE_APP_CHECK_DEBUG_TOKEN=""
