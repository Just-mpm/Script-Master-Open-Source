# API key Gemini NAO e mais necessaria aqui (BYOK).
# Os usuarios fornecem suas proprias chaves dentro do app.

# CORS (opcional)
# Defaults: localhost e dominios Firebase Hosting do projectId atual (<project-id>.web.app, <project-id>.firebaseapp.com).
# Para dominio customizado ou fork em outro dominio, informe a lista completa:
# APP_CORS_ORIGINS=https://seu-dominio.com,https://seu-projeto.web.app,http://localhost:3000

# Firebase Monitoring (opcional)
# ENABLE_FIREBASE_MONITORING=false
