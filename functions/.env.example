# ---------------------------------------------------------------------------
# Variáveis de ambiente — Stripe (template)
# ---------------------------------------------------------------------------
# Copie este arquivo para .env e preencha com as chaves reais:
#   cp .env.example .env
#
# Obtenha as chaves em: https://dashboard.stripe.com/apikeys
# O webhook secret é configurado em: https://dashboard.stripe.com/webhooks
# ---------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ---------------------------------------------------------------------------
# Genkit / Google GenAI
# ---------------------------------------------------------------------------
# Chave de API para o Google GenAI (Gemini).
# O plugin googleAI() do Genkit lê automaticamente esta variável.
# Obtenha em: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------

GOOGLE_GENAI_API_KEY=your-api-key-here

# ---------------------------------------------------------------------------
# 🔒 App Check — OBRIGATÓRIO em produção
# ---------------------------------------------------------------------------
# ⚠️  O frontend PRECISA ter VITE_RECAPTCHA_SITE_KEY configurada para que
#     o App Check inicialize e gere tokens válidos.
# ⚠️  SEM App Check, TODOS os 8 flows de IA (audio, images, assistant, etc.)
#     que usam enforceAppCheck: true vão REJEITAR todas as chamadas em produção.
# ⚠️  O App Check NÃO é configurado no backend — é uma variável do frontend.
#     Certifique-se de que VITE_RECAPTCHA_SITE_KEY está no .env do frontend
#     e que o App Check está habilitado no Console do Firebase (seção App Check).
# ---------------------------------------------------------------------------
#
# Para desenvolvimento local: App Check funciona em modo debug (token local).
# As chaves de debug são geradas em: Console Firebase → App Check → Apps → Debug tokens.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Flags de modo de operação (preparação para fases futuras)
# ---------------------------------------------------------------------------
# BILLING_ENABLED: habilita cobrança por uso de IA (Fase 5)
#   - Quando 'true': endpoints Stripe (/webhook, /checkout, /portal) funcionam
#   - Quando !== 'true': endpoints Stripe retornam 503
#
# OPEN_BETA_ENABLED: mantém acesso gratuito durante beta público (Fase atual)
#   - Quando 'true': flows de IA aceitam chamadas normalmente (acesso gratuito)
#   - Quando !== 'true': middleware openBetaGuard bloqueia flows de IA com 503
#   - Esta flag é PREPARATÓRIA — será desabilitada na Fase 5 quando a cobrança
#     por créditos substituir o acesso gratuito do beta aberto
#   - Não remova esta flag sem antes aplicar openBetaGuard em todos os flows
# ---------------------------------------------------------------------------

BILLING_ENABLED=false
OPEN_BETA_ENABLED=true
